# Database
DATABASE_URL=postgresql://user:password@localhost:5432/amazone

# NextAuth.js
# AUTH_SECRET is used by NextAuth.js v5+. NEXTAUTH_SECRET is the legacy name
# from v4 and is kept here for backwards compatibility. If both are set,
# NextAuth v5 will prefer AUTH_SECRET.
AUTH_SECRET=your-secret-here
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# Stripe
# STRIPE_SECRET_KEY is also used by the stripe-cli Docker service.
# Get your test key from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# When using the stripe-cli Docker service, it prints a webhook signing
# secret (whsec_...) on startup. Copy that value here so the app can
# verify webhook signatures locally.
STRIPE_WEBHOOK_SECRET=whsec_...

# Email / SMTP (defaults to Mailhog in development)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Amazone <noreply@amazone.com>

# Public site URL (used in email links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Redis (optional)
REDIS_URL=redis://localhost:6379

# OpenTelemetry
OTEL_SERVICE_NAME=amazone-web
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SDK_DISABLED=false
