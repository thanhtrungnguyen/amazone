{
  "compilerOptions": {
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022", "dom", "dom.iterable"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "paths": {
      "@amazone/db": ["packages/db/src/index.ts"],
      "@amazone/products": ["packages/products/src/index.ts"],
      "@amazone/cart": ["packages/cart/src/index.ts"],
      "@amazone/checkout": ["packages/checkout/src/index.ts"],
      "@amazone/orders": ["packages/orders/src/index.ts"],
      "@amazone/users": ["packages/users/src/index.ts"],
      "@amazone/reviews": ["packages/reviews/src/index.ts"],
      "@amazone/shared-ui": ["packages/shared-ui/src/index.ts"],
      "@amazone/shared-utils": ["packages/shared-utils/src/index.ts"],
      "@amazone/shared-utils/server": ["packages/shared-utils/src/server.ts"]
    }
  }
}
