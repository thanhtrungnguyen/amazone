{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "NotebookEdit",
      "WebFetch",
      "WebSearch",
      "TodoWrite",
      "Bash(pnpm *)",
      "Bash(pnpm run *)",
      "Bash(pnpm dlx *)",
      "Bash(pnpm nx *)",
      "Bash(pnpm exec *)",
      "Bash(pnpm add *)",
      "Bash(npx nx *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add *)",
      "Bash(git commit*)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git switch*)",
      "Bash(git stash*)",
      "Bash(git merge*)",
      "Bash(git rebase*)",
      "Bash(git fetch*)",
      "Bash(git pull*)",
      "Bash(git push)",
      "Bash(git push -u*)",
      "Bash(git push origin*)",
      "Bash(git tag*)",
      "Bash(git remote*)",
      "Bash(git show*)",
      "Bash(git rev-parse*)",
      "Bash(git cherry-pick*)",
      "Bash(docker compose *)",
      "Bash(docker build *)",
      "Bash(docker run *)",
      "Bash(ls *)",
      "Bash(ls)",
      "Bash(mkdir *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(echo *)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(gh *)",
      "Bash(stripe *)",
      "Bash(curl *)",
      "Bash(cp *)",
      "Bash(mv *)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf *)",
      "Bash(rm -r /)",
      "Bash(git push --force*)",
      "Bash(git push * --force*)",
      "Bash(git push -f*)",
      "Bash(git push * -f *)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(DROP TABLE*)",
      "Bash(DROP DATABASE*)",
      "Bash(TRUNCATE *)",
      "Bash(npm *)",
      "Bash(yarn *)",
      "Bash(chmod 777*)",
      "Bash(> /dev/*)",
      "Bash(docker compose down -v*)",
      "Bash(docker compose rm*)",
      "Bash(rm .env*)",
      "Bash(rm -f .env*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/enforce-write-rules.sh\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/enforce-bash-rules.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "A file was just written/edited. Check if it violates amazone monorepo package boundary rules:\n\n- apps/web can import any @amazone/* package\n- packages/checkout can import @amazone/cart, @amazone/orders, @amazone/db\n- packages/cart can import @amazone/products, @amazone/db\n- packages/orders can import @amazone/products, @amazone/db\n- packages/products can import @amazone/db\n- packages/reviews can import @amazone/products, @amazone/db\n- packages/users can import @amazone/db\n- packages/shared-ui can import @amazone/shared-utils\n- Any package can import @amazone/shared-utils\n- NO package may import from apps/\n\nIf the file contains import statements that violate these rules, explain the violation. If imports are fine or no imports exist, say nothing."
          }
        ]
      }
    ]
  }
}
